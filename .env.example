# Database Configuration
# PostgreSQL connection string - Required for all database operations
# Example for Neon Database: postgresql://username:password@hostname/database?sslmode=require
DATABASE_URL=postgresql://your_username:your_password@your_host:5432/your_database

# Server Configuration  
# Port for the Express server - Default is 5000
PORT=5000

# Node Environment
# Set to 'production' for production deployments, 'development' for local development
NODE_ENV=development

# Optional: Add other environment variables here as needed
# For example:
# CORS_ORIGIN=https://your-domain.com
# JWT_SECRET=your_jwt_secret_key_here